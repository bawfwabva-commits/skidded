		task.wait(0.05)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
	end)
	pcall(function()
		local touchBegin = { Position = Vector2.new(x, y), UserInputState = Enum.UserInputState.Begin, Touch = true }
		UserInputService:FireInputEvent(touchBegin)
		task.wait(0.05)
		local touchEnd = { Position = Vector2.new(x, y), UserInputState = Enum.UserInputState.End, Touch = true }
		UserInputService:FireInputEvent(touchEnd)
	end)
end

local function stackCash()
    print("[DEBUG] Начинаем стакание денег (упрощенная сквозная логика)")
    
    local ui = PlayerGui:FindFirstChild("UI")
    if not ui then return print("[DEBUG] UI не найден") end
    
    local hud = ui:FindFirstChild("HUD")
    if not hud then return print("[DEBUG] HUD не найден") end
    
    local backpack = hud:FindFirstChild("backpackFrame")
    if not backpack then return print("[DEBUG] backpackFrame не найден") end
    
    local loot = backpack:FindFirstChild("loot")
    if not loot then return print("[DEBUG] loot не найден") end

    local inventoryFrame = loot:WaitForChild("inventoryFrame", 5)
    local itemsContainer = inventoryFrame and inventoryFrame:WaitForChild("items", 5)
    if not itemsContainer then return print("[DEBUG] Контейнер items не найден") end

    while true do
        local incompleteCash = {}
        
        for _, itemFrame in ipairs(itemsContainer:GetChildren()) do
            if itemFrame:IsA("Frame") then
                local itemNameLabel = itemFrame:FindFirstChild("itemName")
                local amountLabel = itemFrame:FindFirstChild("amount")

                if itemNameLabel and amountLabel and itemNameLabel.Text == "Cash" then
                    local text = amountLabel.Text
                    if text ~= "$100K" then
                        table.insert(incompleteCash, itemFrame)
                    end
                end
            end
        end
        
        print("[DEBUG] Найдено неполных пачек: " .. #incompleteCash)
        
        if #incompleteCash < 2 then
            print("[DEBUG] Неполных пачек меньше двух. Стакание завершено.")
            break
        end
        
        local targetFrame = incompleteCash[1]
        local sourceFrame = incompleteCash[2]
        
        if targetFrame and targetFrame.Parent and sourceFrame and sourceFrame.Parent then
            print("[DEBUG] Перетаскиваем неполную пачку во вторую для объединения...")
            
            local buttonSource = sourceFrame:FindFirstChild("button") or sourceFrame
            local buttonTarget = targetFrame:FindFirstChild("button") or targetFrame
            
            dragToObject(buttonSource, buttonTarget)
            
            task.wait(0.7)
        else
            task.wait(0.1)
        end
    end
    
    print("[DEBUG] Стакание денег полностью завершено")
end

local function sellAll()
	print("[DEBUG] Начинаем продажу")
	local ui = PlayerGui:FindFirstChild("UI")
	if not ui then 
		print("[DEBUG] UI не найден")
		return 
	end
	print("[DEBUG] UI найден")
	
	local inventoryCategory = ui:FindFirstChild("inventoryCategory")
	if inventoryCategory then
		print("[DEBUG] inventoryCategory найден")
		local overall = inventoryCategory:FindFirstChild("overall")
		if overall then
			print("[DEBUG] overall найден, кликаем")
			clickObject(overall)
			task.wait(0.25)
		else
			print("[DEBUG] overall не найден")
		end
	else
		print("[DEBUG] inventoryCategory не найден")
	end
	
	local hud = ui:FindFirstChild("HUD")
	if not hud then 
		print("[DEBUG] HUD не найден")
		return 
	end
	print("[DEBUG] HUD найден")
	
	local backpack = hud:FindFirstChild("backpackFrame")
	if not backpack then 
		print("[DEBUG] backpackFrame не найден")
		return 
	end
	print("[DEBUG] backpackFrame найден")
	
	local trader = backpack:FindFirstChild("traderCenterFrame") or backpack:FindFirstChild("trader")
	if not trader then 
		print("[DEBUG] trader не найден")
		return 
	end
	print("[DEBUG] trader найден")
	
	local tradesellswitch = trader:FindFirstChild("traderSellButton")
	local realsellbutton = trader:FindFirstChild("dealButtonFrame") and trader.dealButtonFrame:FindFirstChild("dealButton")
	
	if not tradesellswitch or not realsellbutton then 
		print("[DEBUG] tradesellswitch или realsellbutton не найден")
		return 
	end
	print("[DEBUG] tradesellswitch и realsellbutton найдены")
	
	task.wait(0.25)
	clickObject(tradesellswitch)
	print("[DEBUG] Нажали на traderSellButton")
	
	local playerContainer = backpack:FindFirstChild("player")
	if not playerContainer then 
		print("[DEBUG] playerContainer не найден")
		return 
	end
	print("[DEBUG] playerContainer найден")
	
	local pocket = nil
    local DuffelBag = nil
    local Vest = nil
	
	for _, child in ipairs(playerContainer:GetChildren()) do
		if child:IsA("Frame") and child.Name == "inventoryFrame" and child:GetAttribute("childrens") == 8 then
			pocket = child
			print("[DEBUG] Найден pocket")
			break
		end
	end

    for _, child in ipairs(playerContainer:GetChildren()) do
		if child:IsA("Frame") and child.Name == "inventoryFrame" and child:GetAttribute("childrens") == 9 then
			DuffelBag = child
			print("[DEBUG] Найден DuffelBag")
			break
		end
	end

    for _, child in ipairs(playerContainer:GetChildren()) do
		if child:IsA("Frame") and child.Name == "inventoryFrame" and child:GetAttribute("childrens") == 4 then
			Vest = child
			print("[DEBUG] Найден Vest")
			break
		end
	end

	if not pocket then 
		print("[DEBUG] pocket не найден")
		return 
	end
	
	local itemsContainer = pocket:FindFirstChild("items") or pocket
	print("[DEBUG] Продаем предметы из pocket")
	for _, itemFrame in ipairs(itemsContainer:GetChildren()) do
		if itemFrame:IsA("Frame") then
			local button = itemFrame:FindFirstChild("button")
			if button then
				clickObject(button)
				task.wait(0.05)
			end
		end
	end

	if DuffelBag then
		local itemsContainerDuffelBag = DuffelBag:FindFirstChild("items") or DuffelBag
		print("[DEBUG] Продаем предметы из DuffelBag")
		for _, itemFrame in ipairs(itemsContainerDuffelBag:GetChildren()) do
			if itemFrame:IsA("Frame") then
				local button = itemFrame:FindFirstChild("button")
				if button then
					clickObject(button)
					task.wait(0.05)
				end
			end
		end
	end

	if Vest then
		local itemsContainerVest = Vest:FindFirstChild("items") or Vest
		print("[DEBUG] Продаем предметы из Vest")
		for _, itemFrame in ipairs(itemsContainerVest:GetChildren()) do
			if itemFrame:IsA("Frame") then
				local button = itemFrame:FindFirstChild("button")
				if button then
					clickObject(button)
					task.wait(0.05)
				end
			end
		end
	end

    clickObject(realsellbutton)
	print("[DEBUG] Нажали sell button")
	task.wait(0.5)

	local status = backpack:FindFirstChild("status")
	if status then
		print("[DEBUG] Найден status")
		local overall = status:FindFirstChild("overallFrame")
		if overall then
			print("[DEBUG] Найден overallFrame")
			local equipSlots = overall:FindFirstChild("equipment") and overall.equipment:FindFirstChild("slots")
			if equipSlots then
				print("[DEBUG] Продаем экипировку")
				for _, slot in ipairs(equipSlots:GetChildren()) do
					if slot:IsA("Frame") and slot:FindFirstChildOfClass("ObjectValue") then
						local button = slot:FindFirstChild("button")
						if button then clickObject(button) else clickObject(slot) end
						task.wait(0.05)
					end
				end
			end
			local weaponSlots = overall:FindFirstChild("weapons") and overall.weapons:FindFirstChild("slots")
			if weaponSlots then
				print("[DEBUG] Продаем оружие")
				for _, slot in ipairs(weaponSlots:GetChildren()) do
					if slot:IsA("Frame") and slot:FindFirstChildOfClass("ObjectValue") then
						local button = slot:FindFirstChild("button")
						if button then clickObject(button) else clickObject(slot) end
						task.wait(0.05)
					end
				end
			end
		end
	end
	
	clickObject(realsellbutton)
	print("[DEBUG] Нажали sell button второй раз")
	task.wait(0.5)
	
	-- Теперь открываем stash и стакаем деньги
	print("[DEBUG] Открываем stash для стакания денег")
	local lobbyBottom = PlayerGui:FindFirstChild("UI") and PlayerGui.UI:FindFirstChild("mainMenuFrame") and PlayerGui.UI.mainMenuFrame:FindFirstChild("lobbyBottom")
	if lobbyBottom then
		local stash = lobbyBottom:FindFirstChild("main") and lobbyBottom.main:FindFirstChild("stash")
		if stash then
			print("[DEBUG] Stash найден, открываем")
			clickObject(stash)
			task.wait(0.5)
			
			-- Стакаем деньги в stash
			print("[DEBUG] Запускаем стакание денег в stash")
			stackCash()
			print("[DEBUG] Стакание денег в stash завершено")
		else
			print("[DEBUG] Stash НЕ найден в lobbyBottom.main")
		end
	else
		print("[DEBUG] lobbyBottom не найден")
	end
	
	print("[DEBUG] Продажа завершена")
end

local function checkPrompt()
	local ui = PlayerGui:FindFirstChild("UI")
	if not ui then return false end
	local prompt = ui:FindFirstChild("__prompt")
	if not prompt then return false end
	local promptButtons = prompt:FindFirstChild("promptButtons")
	if not promptButtons then return false end
	local promptButton1 = promptButtons:FindFirstChild("promptButton1")
	if promptButton1 and promptButton1.Visible then
		clickObject(promptButton1)
		task.wait(0.5)
		return true
	end
	return false
end

local function waitForMainMenu()
	print("[DEBUG] Ожидаем главное меню")
	while true do
		clickCenter()
		task.wait(0.1)
		local lobbyBottom = PlayerGui:FindFirstChild("UI") and PlayerGui.UI:FindFirstChild("mainMenuFrame") and PlayerGui.UI.mainMenuFrame:FindFirstChild("lobbyBottom")
		if lobbyBottom and lobbyBottom.Visible then
			print("[DEBUG] Главное меню найдено")
			return lobbyBottom
		end
	end
end

while true do
	print("[DEBUG] === НАЧАЛО НОВОГО ЦИКЛА ===")
	local lobbyBottom = waitForMainMenu()
	
	for _ = 1, 5 do
		if checkPrompt() then break end
		task.wait(0.1)
	end
	
